# --- Core ---
SECRET_KEY=cambia-questo-con-una-stringa-random-sicura
BASE_URL=https://agentia-production-fb78.up.railway.app

# --- Database ---
# Supabase session pooler (port 5432, NOT 6543)
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./vynex.db

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# --- Email (Resend) ---
# Opzionale: se assente, emailer fa no-op senza errori
RESEND_API_KEY=re_...
EMAIL_FROM=VYNEX <ciao@vynex.it>
EMAIL_REPLY_TO=ciao@vynex.it

# --- Admin ---
# Per GET /admin/metrics — header: X-Admin-Token: <token>
ADMIN_TOKEN=genera-stringa-random-lunga-qui

# --- Google Sign-In (GIS — client-side, solo Client ID) ---
# Nessun secret richiesto: usa Google Identity Services (JWT firmato client-side).
# 1. https://console.cloud.google.com/ → crea progetto (es. vynex-auth)
# 2. APIs & Services → OAuth consent screen → External → compila app name + support email
# 3. Credentials → Create OAuth client ID → Web application
# 4. Authorized JavaScript origins:
#    - https://agentia-production-fb78.up.railway.app
#    - http://localhost:8000
# 5. Authorized redirect URIs:
#    - https://agentia-production-fb78.up.railway.app/auth/google/verify
#    - http://localhost:8000/auth/google/verify
# 6. Copia SOLO il Client ID (il Secret NON serve).
GOOGLE_CLIENT_ID=

# --- Logging ---
LOG_LEVEL=INFO
